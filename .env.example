# ── App ──────────────────────────────────────────────
APP_ENV=development
APP_NAME=Resumi
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=512
OPENAI_EMBEDDING_BATCH_SIZE=32

# ── LangChain (optionnel) ────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGSMITH_API_KEY=

# ── Stockage ─────────────────────────────────────────
DOCS_ROOT=docs
FAISS_INDEX_DIR=.data/faiss

# ── Gmail ────────────────────────────────────────────
GMAIL_MAX_RESULTS=1000
GMAIL_CLIENT_SECRETS_FILE=credentials/gmail-client-secret.json
GMAIL_TOKEN_FILE=credentials/gmail-token.json
GMAIL_QUERY=in:anywhere
GMAIL_USER_ID=me

# ── Gradio ───────────────────────────────────────────
GRADIO_PATH=/gradio

# ── Google Calendar (optionnel) ──────────────────────
GOOGLE_CALENDAR_ID=primary
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/google-service-account.json
